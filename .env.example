# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  CẤU HÌNH MÔI TRƯỜNG — Quản lý Điểm Rèn luyện Sinh viên                  ║
# ║                                                                          ║
# ║  Cách dùng:                                                              ║
# ║  1. Copy file này: cp .env.example .env                                  ║
# ║  2. Sửa các giá trị có "THAY_DOI_TOI" trong .env                         ║
# ║  3. KHÔNG commit file .env lên Git (đã có trong .gitignore)              ║
# ╚══════════════════════════════════════════════════════════════════════════╝


# ═══════════════════════════════════════════════════════════════════════════
# 1. DATABASE (Prisma + SQLite)
# ═══════════════════════════════════════════════════════════════════════════

# Đường dẫn file SQLite — tính TƯƠNG ĐỐI so với thư mục prisma/ (nơi đặt
# schema.prisma), nên "file:./dev.db" → file thực tế ở prisma/dev.db.
# KHÔNG cần đổi nếu dùng mặc định.
DATABASE_URL="file:./dev.db"


# ═══════════════════════════════════════════════════════════════════════════
# 2. AUTHENTICATION (next-auth v5)
# ═══════════════════════════════════════════════════════════════════════════

# Chuỗi bí mật để ký session token.
# ⚠️ BẮT BUỘC đổi trước khi triển khai. Tối thiểu 32 ký tự.
#
# Cách sinh chuỗi ngẫu nhiên:
#   - macOS/Linux: openssl rand -base64 32
#   - Windows PS:  [Convert]::ToBase64String((1..32 | %{[byte](Get-Random -Max 256)}))
#   - Online:      https://generate-secret.vercel.app/32
AUTH_SECRET="THAY_DOI_TOI_chuoi_bi_mat_toi_thieu_32_ky_tu_xxxxxxxxxxxxxxxxxxxxx"

# URL ứng dụng. Local mặc định http://localhost:3000.
# Khi deploy LAN nội bộ, đổi thành IP máy chủ: http://192.168.1.10:3000
AUTH_URL="http://localhost:3000"

# Thời gian session timeout (giây). Mặc định 30 phút = 1800 giây.
SESSION_MAX_AGE=1800


# ═══════════════════════════════════════════════════════════════════════════
# 3. FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════════════════

# Bật/tắt tính năng Import Excel qua UI.
# - false (MẶC ĐỊNH): ẩn nút "Import Excel" + API trả 403.
# - true: hiện nút trên trang /scores + API hoạt động.
#
# Sau khi đổi giá trị → BẮT BUỘC restart server (Ctrl+C → npm run dev).
IMPORT_EXCEL_ENABLED=false


# ═══════════════════════════════════════════════════════════════════════════
# 4. APP CONFIG
# ═══════════════════════════════════════════════════════════════════════════

# Tên hiển thị trên topbar và browser tab.
NEXT_PUBLIC_APP_NAME="Quản lý Điểm Rèn luyện"

# Tên đơn vị hiển thị ở footer / báo cáo.
NEXT_PUBLIC_ORGANIZATION="Khoa KHTN và CNTT - Trường Đại học Phú Yên"


# ═══════════════════════════════════════════════════════════════════════════
# 5. BACKUP (tùy chọn)
# ═══════════════════════════════════════════════════════════════════════════

# Thư mục lưu file backup DB. Mặc định ./backups
BACKUP_DIR="./backups"

# Số ngày giữ backup tối đa (cũ hơn sẽ tự xóa khi tạo backup mới).
# Đặt 0 = giữ vĩnh viễn.
BACKUP_RETENTION_DAYS=30


# ═══════════════════════════════════════════════════════════════════════════
# 6. LOGGING (tùy chọn)
# ═══════════════════════════════════════════════════════════════════════════

# Mức log: error | warn | info | debug
LOG_LEVEL=info

# Bật log truy vấn Prisma ra console (chỉ dùng khi debug).
PRISMA_QUERY_LOG=false


# ═══════════════════════════════════════════════════════════════════════════
# 7. MÔI TRƯỜNG NODE
# ═══════════════════════════════════════════════════════════════════════════

# Tự động đặt bởi Next.js, không cần sửa.
# NODE_ENV=development
